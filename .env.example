# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client. Used by API routes/webhooks.
SUPABASE_SERVICE_ROLE_KEY=

# ---- App ----
# Canonical app origin, e.g. https://yoters.example.com
# Used for password-reset links and to scope CORS on /api responses.
NEXT_PUBLIC_APP_URL=

# ---- Roles / identity (replaces hardcoded emails) ----
# Comma-separated allowlists.
NEXT_PUBLIC_ADMIN_EMAILS=
NEXT_PUBLIC_MANAGER_EMAILS=

# ---- Razorpay ----
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Razorpay webhook secret / HMAC key (server-only).
# Payouts (server-only). Configure to enable the admin payout endpoint.
RAZORPAY_PAYOUT_KEY_ID=
RAZORPAY_PAYOUT_ACCOUNT_NUMBER=

# ---- Twilio (SMS notifications) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Resend (transactional email: lockout notifications) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---- Supabase Auth lifecycle webhook ----
# Shared secret sent as the `x-webhook-secret` header from the Supabase DB
# webhook on auth.users (INSERT/DELETE) to /api/auth/webhook.
SUPABASE_WEBHOOK_SECRET=
